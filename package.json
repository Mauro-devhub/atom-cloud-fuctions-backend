{
  "name": "atom-cloud-functions-backend",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/server.js",
    "deploy": "npm run build && gcloud functions deploy helloHttp --runtime nodejs20 --trigger-http --allow-unauthenticated --source=. --entry-point=helloHttp"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.1.0",
    "@types/express": "^4.17.25",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
